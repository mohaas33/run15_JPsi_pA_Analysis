<command> 
        starver SL20a 
        setup 64b 
        cons 
        root4star -q -b sDstAna.C\(\"$FILELIST\",\"$SCRATCH\",\"$JOBID\"\)
</command> 

<SandBox installer="ZIP">
        <Package>
              	<File>file:./sDstAna.C</File>
	 	<File>file:./StRoot</File>
                <File>file:./pA_eff.root</File>
        </Package>
</SandBox>

<Generator><Location>
      /gpfs01/star/pwg/eshulga/tmp_output/scheduler/
</Location></Generator>

<input URL="file:/gpfs01/star/pwg/eshulga/Files/skim_from_MuDST_pA_new/*.histograms.root" nFiles="all" />

